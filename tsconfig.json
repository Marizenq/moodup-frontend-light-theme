{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "jsx": "react-native",  // ← ADICIONE ESTA LINHA
    "strict": true,
    "baseUrl": ".",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["src/*"],
     "typeRoots": [
      "./node_modules/@types",
      "./src/types"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "src"
  ]
}